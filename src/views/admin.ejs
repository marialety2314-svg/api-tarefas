<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Admin - App Tarefas</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    <div class="container">
      <h1>Painel Administrativo</h1>
      <nav>
        <span>Olá, <strong><%= session.userName %></strong> (ADMIN)</span>
        <a href="/tarefas">Minhas Tarefas</a>
        <a href="/logout">Sair</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <% if (flash) { %>
      <div class="flash"><%= flash %></div>
    <% } %>

    <section class="card">
      <h2>Lista de Usuários e Tarefas</h2>
      <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
        <thead>
          <tr style="border-bottom: 2px solid #ddd; text-align: left;">
            <th style="padding: 10px;">ID</th>
            <th style="padding: 10px;">Nome</th>
            <th style="padding: 10px;">Email</th>
            <th style="padding: 10px;">Papel</th>
            <th style="padding: 10px;">Tarefas</th>
          </tr>
        </thead>
        <tbody>
          <% usuarios.forEach(u => { %>
            <tr style="border-bottom: 1px solid #eee;">
              <td style="padding: 10px;"><%= u.id %></td>
              <td style="padding: 10px;"><%= u.nome %></td>
              <td style="padding: 10px;"><%= u.email %></td>
              <td style="padding: 10px;">
                <span style="padding: 2px 8px; border-radius: 4px; font-size: 0.8em; background: <%= u.role === 'ADMIN' ? '#ffd700' : '#e0e0e0' %>">
                  <%= u.role %>
                </span>
              </td>
              <td style="padding: 10px;">
                <ul>
                  <% u.tarefas.forEach(t => { %>
                    <li style="font-size: 0.9em; color: <%= t.concluida ? '#888' : '#333' %>; text-decoration: <%= t.concluida ? 'line-through' : 'none' %>">
                      <%= t.texto %>
                    </li>
                  <% }) %>
                  <% if (u.tarefas.length === 0) { %>
                    <li style="font-size: 0.9em; color: #999; list-style: none;">Nenhuma tarefa</li>
                  <% } %>
                </ul>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
