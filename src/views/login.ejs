<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Login</title><link rel="stylesheet" href="/css/styles.css"></head>
<body><div class="container" style="margin-top:60px">
  <div class="center"><h2>📋 Minhas Tarefas</h2><p>Faça login para ver suas tarefas</p></div>
  <% if (flash) { %><div class="flash"><%= flash %></div><% } %>
  <div class="card"><h2>🔐 Login</h2>
    <form method="POST" action="/login">
      <div class="form-group"><label>Email</label><input type="email" name="email" required autofocus></div>
      <div class="form-group"><label>Senha</label><input type="password" name="senha" required></div>
      <button type="submit" class="btn btn-primary">Entrar</button>
    </form>
    <div class="link">Não tem conta? <a href="/registro">Criar conta</a></div>
  </div>
</div></body></html>
